# 本機 PostgreSQL 範例：
# DATABASE_URL=postgresql+psycopg://wuwagroup:wuwagroup@localhost:5432/wuwagroup
# Supabase 範例（於 Supabase 專案 Settings > Database > Connection string 取得，將 postgresql:// 改為 postgresql+psycopg://）：
# DATABASE_URL=postgresql+psycopg://postgres:<password>@<project-ref>.supabase.co:5432/postgres
DATABASE_URL=postgresql+psycopg://wuwagroup:wuwagroup@localhost:5432/wuwagroup
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ALLOWED_ORIGINS=http://localhost:5173
UPLOAD_DIRECTORY=./uploads
